aws_region  = "us-east-1"
project_name = "three-tier-infra"
environment  = "dev"

vpc_cidr = "10.0.0.0/16"
az_count = 2

public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

instance_type = "t3.micro"
key_name      = "" # set to an existing EC2 key pair name if you need SSH access
ami_id        = "" # leave empty to auto-select latest Amazon Linux 2023
